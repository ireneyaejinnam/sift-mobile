# Supabase — ingest pipeline (server-side)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_jwt

# Supabase — frontend (Expo public vars)
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_jwt

# Anthropic — AI discovery (web search) in data collection pipeline (console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI — AI data collection pipeline: enrich, dedup, hooks, scoring, images (platform.openai.com)
OPENAI_API_KEY=your_openai_api_key

# Tavily — web search for image resolution in data collection pipeline (tavily.com)
TAVILY_API_KEY=your_tavily_api_key

# Optional: LLM provider override (auto|claude|openai). Default: auto
# auto = Claude for discovery, OpenAI for everything else
# LLM_PROVIDER=auto

# Google Gemini — installed but unused (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# Ticketmaster (developer.ticketmaster.com)
TICKETMASTER_API_KEY=your_api_key

# Eventbrite — use the private token
EVENTBRITE_OAUTH_TOKEN=your_private_token

# NYC Gov Event Calendar API (api-portal.nyc.gov)
NYC_EVENT_CALENDAR_KEY=your_nyc_event_calendar_key

# Amplitude (amplitude.com > Settings > Projects)
EXPO_PUBLIC_AMPLITUDE_API_KEY=your_amplitude_api_key

# Firebase Analytics — Measurement Protocol REST API (no native SDK)
# Get these from Firebase Console > Project Settings > Your Apps
EXPO_PUBLIC_FIREBASE_IOS_APP_ID=your_ios_app_id
EXPO_PUBLIC_FIREBASE_IOS_API_SECRET=your_ios_api_secret
EXPO_PUBLIC_FIREBASE_ANDROID_APP_ID=your_android_app_id
EXPO_PUBLIC_FIREBASE_ANDROID_API_SECRET=your_android_api_secret