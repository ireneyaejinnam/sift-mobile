{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/ingest",
      "schedule": "0 7 * * *"
    }
  ]
}
